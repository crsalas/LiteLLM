# Required for accessing the proxy from OpenAI clients.
# Keep this file blank in git; .env is generated locally and should never be committed.
LITELLM_MASTER_KEY=

# Comma-separated provider env keys to enforce as required.
# Example: OPENAI_API_KEY,ANTHROPIC_API_KEY,GEMINI_API_KEY
# Leave blank to auto-require only non-empty provider keys.
LITELLM_REQUIRED_PROVIDER_KEYS=OPENAI_API_KEY,ANTHROPIC_API_KEY,GEMINI_API_KEY

# Run the container as your host UID/GID (auto-populated by ./scripts/up.sh).
LITELLM_UID=
LITELLM_GID=

# OpenAI provider key.
OPENAI_API_KEY=

# Anthropic provider key.
ANTHROPIC_API_KEY=

# Canonical key for Gemini API (Google AI Studio).
# This repo uses GEMINI_API_KEY as the single source of truth.
# If you only have GOOGLE_API_KEY, copy it into GEMINI_API_KEY.
GEMINI_API_KEY=

# Optional for provider SDK compatibility in some environments.
# GOOGLE_API_KEY=
GOOGLE_API_KEY=

# Vertex AI runtime settings (required only if using Vertex-based models).
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-central1
# Path mounted into the container for ADC JSON credentials.
VERTEX_ADC_CREDENTIALS_PATH=./.local/adc/application_default_credentials.json
